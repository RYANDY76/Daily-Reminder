# Supabase (couple cross-device sync + cloud backup)
# Jalankan supabase-schema.sql di SQL Editor Supabase (file lengkap di root project)
# Atau: npm run supabase:push (setelah supabase link)
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Sentry (optional — error & performance monitoring)
# Buat project di https://sentry.io, ambil DSN, set di sini
VITE_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxx

# Web Push (optional — npm run generate-vapid)
VITE_VAPID_PUBLIC_KEY=BNx...

# Sentry — kirim error & performance data ke Sentry dashboard
VITE_SENTRY_DSN=

# Supabase Edge Function secrets (set via: npx supabase secrets set KEY=value)
# VAPID_PUBLIC_KEY=        # same as VITE_VAPID_PUBLIC_KEY
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@yourdomain.com
# REMINDER_TIMEZONE=Asia/Jakarta
# CRON_SECRET=             # optional, for scheduled check-reminders
